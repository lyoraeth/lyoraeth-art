# Sanity CMS
NUXT_SANITY_PROJECT_ID=your_project_id_here
NUXT_SANITY_DATASET=production
# Write token — create at sanity.io/manage → API → Tokens → Add API token (Editor role)
NUXT_SANITY_TOKEN=your_sanity_write_token_here

# Cloudflare Turnstile — get keys at dash.cloudflare.com → Turnstile
# Blog comments widget (visible)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
NUXT_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Contact form widget (invisible — create a separate "Invisible" widget type in CF dashboard)
NUXT_PUBLIC_TURNSTILE_SITE_KEY_CONTACT=1x00000000000000000000AA
NUXT_TURNSTILE_SECRET_KEY_CONTACT=1x0000000000000000000000000000000AA

# Mailer (SMTP) — contact form
NUXT_MAILER_HOST=smtp.gmail.com
NUXT_MAILER_PORT=587
NUXT_MAILER_USER=your@gmail.com
NUXT_MAILER_PASS=your_app_password_here
NUXT_MAILER_TO=your@gmail.com

# Umami analytics (self-hosted)
# NUXT_PUBLIC_UMAMI_WEBSITE_ID and NUXT_PUBLIC_UMAMI_SCRIPT_URL are set after first Umami deploy
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://stat.lyoraeth.art/script.js

# Umami docker (used by docker-compose.yml only, not by Nuxt)
UMAMI_DB_PASSWORD=change_me_strong_password
UMAMI_APP_SECRET=change_me_random_32chars
